###############################################################################
# DEV Environment - terraform.tfvars
###############################################################################

project_name = "ecommerce-ciam"
environment  = "dev"
aws_region   = "us-east-1"

###############################################################################
# Networking
###############################################################################

vpc_cidr = "10.10.0.0/16"

availability_zones = [
  "us-east-1a",
  "us-east-1b",
  "us-east-1c"
]

public_subnet_cidrs = [
  "10.10.1.0/24",
  "10.10.2.0/24",
  "10.10.3.0/24"
]

private_app_subnet_cidrs = [
  "10.10.11.0/24",
  "10.10.12.0/24",
  "10.10.13.0/24"
]

private_data_subnet_cidrs = [
  "10.10.21.0/24",
  "10.10.22.0/24",
  "10.10.23.0/24"
]

# Developer office IPs allowed to access public EKS endpoint
developer_cidr_blocks = [
  "203.0.113.0/24",  # Replace with actual developer IP ranges
  "198.51.100.0/24"
]

###############################################################################
# Kubernetes
###############################################################################

kubernetes_version = "1.31"

###############################################################################
# Aurora
###############################################################################

aurora_engine_version = "16.2"
db_name               = "ciam_db"
db_master_username    = "ciam_admin"
# db_master_password  - set via environment variable TF_VAR_db_master_password

###############################################################################
# Redis
###############################################################################

redis_engine_version = "7.1"

###############################################################################
# Kafka
###############################################################################

kafka_version = "3.6.0"

###############################################################################
# OpenSearch
###############################################################################

opensearch_version = "2.13"

# Set to false if service-linked role already exists in the account
create_opensearch_slr = true

###############################################################################
# Domain
###############################################################################

domain_name = "ecommerce-ciam.example.com"

###############################################################################
# Monitoring
###############################################################################

alarm_email_endpoints = [
  "dev-alerts@example.com"
]

###############################################################################
# Common Tags
###############################################################################

common_tags = {
  Environment = "dev"
  Project     = "ecommerce-ciam"
  Team        = "Platform-Engineering"
  CostCenter  = "CIAM-DEV"
  Terraform   = "true"
}
